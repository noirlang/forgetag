{
  "name": "forgetag",
  "version": "0.0.2",
  "private": true,
  "author": "noirLang",
  "workspaces": [
    "apps/desktop"
  ],
  "scripts": {
    "dev": "npm --workspace @forgetag/desktop run dev",
    "build": "npm --workspace @forgetag/desktop run build",
    "desktop": "tauri dev --config src-tauri/tauri.conf.json",
    "build:linux:appimage": "tauri build --config src-tauri/tauri.conf.json --bundles appimage",
    "build:windows:msi": "tauri build --config src-tauri/tauri.conf.json --bundles msi"
  }
}
